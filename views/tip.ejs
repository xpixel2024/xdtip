<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Uplink: Support <%= user.name %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    
    <script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>

    <style>
        /* Keeping your original CSS styles exactly the same */
        :root { --neon-cyan: #00f3ff; --neon-magenta: #ff00ea; --bg-dark: #03040b; --panel-bg: rgba(5, 8, 20, 0.85); --grid-color: rgba(0, 243, 255, 0.05); }
        body { margin: 0; font-family: 'Rajdhani', sans-serif; background-color: var(--bg-dark); color: #c8d3f5; overflow-x: hidden; }
        .bgfx { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background-image: linear-gradient(var(--grid-color) 1px, transparent 1px), linear-gradient(90deg, var(--grid-color) 1px, transparent 1px); background-size: 40px 40px; }
        .bgfx::after { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06)); background-size: 100% 4px, 3px 100%; pointer-events: none; }
        .container { display: flex; min-height: 100vh; justify-content: center; align-items: center; padding: 20px; }
        .card { background: var(--panel-bg); border: 1px solid rgba(0, 243, 255, 0.2); box-shadow: 0 0 30px rgba(0, 243, 255, 0.1); padding: 40px 30px; width: 100%; max-width: 420px; backdrop-filter: blur(10px); position: relative; }
        .card::before, .card::after { content: ''; position: absolute; width: 20px; height: 20px; border: 2px solid var(--neon-cyan); }
        .card::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
        .card::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
        .sys-label { position: absolute; top: -12px; left: 20px; background: var(--bg-dark); padding: 0 10px; color: var(--neon-cyan); font-family: 'Share Tech Mono', monospace; font-size: 12px; letter-spacing: 1px; }
        .profile-header { text-align: center; margin-bottom: 30px; }
        .avatar-wrapper { position: relative; width: 110px; height: 110px; margin: 0 auto 15px; display: flex; justify-content: center; align-items: center; background: var(--neon-cyan); clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); box-shadow: 0 0 20px var(--neon-cyan); }
        .avatar { width: 104px; height: 104px; background: #111; background-size: cover; background-position: center; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); }
        .creator-name { font-size: 28px; font-weight: 700; color: #fff; margin: 0; text-shadow: 0 0 10px var(--neon-cyan); text-transform: uppercase; }
        .creator-handle { font-family: 'Share Tech Mono', monospace; color: #8fa1d0; font-size: 14px; margin-top: 5px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; color: var(--neon-magenta); font-family: 'Share Tech Mono', monospace; font-size: 12px; margin-bottom: 5px; }
        input, textarea { width: 100%; box-sizing: border-box; padding: 12px 15px; background: rgba(0, 0, 0, 0.6); border: 1px solid #333; border-left: 3px solid var(--neon-cyan); color: var(--neon-cyan); font-family: 'Share Tech Mono', monospace; font-size: 16px; outline: none; }
        .currency-wrapper { position: relative; }
        .currency-wrapper span { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: var(--neon-cyan); font-family: 'Share Tech Mono', monospace; font-weight: bold; }
        .currency-wrapper input { padding-left: 35px; }
        .btn { width: 100%; padding: 15px; background: rgba(0, 243, 255, 0.05); border: 1px solid var(--neon-cyan); color: var(--neon-cyan); font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 18px; cursor: pointer; transition: 0.3s; clip-path: polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px); }
        .btn:hover:not(:disabled) { background: var(--neon-cyan); color: #000; box-shadow: 0 0 25px var(--neon-cyan); }
    </style>
</head>
<body>

    <div class="bgfx"></div>

    <div class="container">
        <div class="card">
            <div class="sys-label">SECURE_PAYMENT_NODE</div>
            <div class="profile-header">
                <div class="avatar-wrapper">
                    <% if (user.logo && user.logo.trim() !== '') { %>
                        <div class="avatar" style="background-image: url('<%= user.logo %>');"></div>
                    <% } else { %>
                        <div class="avatar fallback-avatar" style="display:flex; align-items:center; justify-content:center; color:var(--neon-cyan); font-size:40px; font-weight:bold;">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                </div>
                <h1 class="creator-name"><%= user.name %></h1>
                <div class="creator-handle">> ID: <%= user.username %></div>
            </div>

            <form id="payment-form">
                <div class="form-group">
                    <label>> SENDER IDENTITY (NAME)</label>
                    <input type="text" id="sender-name" required placeholder="Enter your name...">
                </div>
                <div class="form-group">
                    <label>> TRANSMIT PAYLOAD (MESSAGE)</label>
                    <textarea id="sender-message" rows="3" placeholder="Enter transmission data..."></textarea>
                </div>
                <div class="form-group">
                    <label>> ALLOCATE CREDITS (INR)</label>
                    <div class="currency-wrapper">
                        <span>₹</span>
                        <input type="number" id="tip-amount" required min="10" placeholder="100">
                    </div>
                </div>
                <button type="submit" id="pay-button" class="btn">
                    [ TRANSMIT CREDITS ]
                </button>
            </form>
        </div>
    </div>

    <script>
    // Initialize Cashfree
    const cashfree = Cashfree({
    mode: "sandbox" // Change to "production" when your Render env is set to live
});

const form = document.getElementById('payment-form');
const payBtn = document.getElementById('pay-button');
const creatorUsername = "<%= user.username %>";

form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name = document.getElementById('sender-name').value;
    const message = document.getElementById('sender-message').value;
    const amount = document.getElementById('tip-amount').value;

    payBtn.innerText = "INITIALIZING UPLINK...";
    payBtn.disabled = true;

    try {
        // STEP 1: Request a session from your Backend
        const response = await fetch('/api/create-cashfree-order', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                amount: amount,
                username: creatorUsername,
                customerName: name,
                customerMessage: message
            })
        });

        const orderData = await response.json();

        if (!orderData.payment_session_id) {
            throw new Error("Could not establish payment session.");
        }

        // STEP 2: Open the Cashfree Checkout Overlay
        let checkoutOptions = {
            paymentSessionId: orderData.payment_session_id,
            redirectTarget: "_self", 
        };

        cashfree.checkout(checkoutOptions);

    } catch (err) {
        alert("CRITICAL ERROR: " + err.message);
        payBtn.disabled = false;
        payBtn.innerText = "[ TRANSMIT CREDITS ]";
    }
});
    </script>
</body>
</html>
