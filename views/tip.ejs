<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support <%= user.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">

    <div class="bg-white rounded-2xl shadow-xl p-8 max-w-md w-full border border-gray-100">
        <div class="text-center mb-8">
            <div class="w-20 h-20 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-bold">
                <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <h1 class="text-2xl font-bold text-gray-800">Support <%= user.name %></h1>
            <p class="text-gray-500 text-sm mt-1">@<%= user.username %></p>
        </div>

        <form id="payment-form" class="space-y-5">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Your Name</label>
                <input type="text" id="sender-name" required placeholder="Enter your name" 
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all">
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Message</label>
                <textarea id="sender-message" rows="3" placeholder="Say something nice (optional)" 
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all"></textarea>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Amount (₹)</label>
                <div class="relative">
                    <span class="absolute left-4 top-3 text-gray-400 font-medium">₹</span>
                    <input type="number" id="tip-amount" required min="10" placeholder="100" 
                        class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all">
                </div>
                <p class="text-xs text-gray-400 mt-2">Minimum support amount is ₹10</p>
            </div>

            <button type="submit" id="pay-button" 
                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-200 transition-all transform active:scale-[0.98]">
                Send Tip
            </button>
        </form>
    </div>

    <script>
        const form = document.getElementById('payment-form');
        const payBtn = document.getElementById('pay-button');

        // These variables are injected by EJS from the server
        const creatorId = "<%= user.id %>";
        const creatorName = "<%= user.name %>";

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const name = document.getElementById('sender-name').value;
            const message = document.getElementById('sender-message').value;
            const amount = document.getElementById('tip-amount').value;

            if (amount < 10) {
                alert("Please enter at least ₹10");
                return;
            }

            payBtn.innerText = "Opening Secure Checkout...";
            payBtn.disabled = true;

            const options = {
                "key": "YOUR_RAZORPAY_KEY_ID", // Replace with your actual Test/Live Key
                "amount": amount * 100, // Amount in paise
                "currency": "INR",
                "name": "Tip for " + creatorName,
                "description": "Support Content Creation",
                "handler": async function (response) {
                    // 1. Payment Successful! Now tell the server to save it to Supabase
                    payBtn.innerText = "Saving your tip...";
                    
                    try {
                        const saveResponse = await fetch('/api/tip', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                userId: creatorId,
                                name: name,
                                message: message,
                                amount: amount,
                                payment_id: response.razorpay_payment_id
                            })
                        });

                        const result = await saveResponse.json();

                        if (result.success) {
                            alert("Success! Your tip was sent to " + creatorName);
                            window.location.reload();
                        } else {
                            alert("Payment worked, but there was an error saving to database.");
                        }
                    } catch (err) {
                        console.error(err);
                        alert("Network error while saving payment.");
                    }
                },
                "prefill": {
                    "name": name
                },
                "theme": {
                    "color": "#2563EB"
                },
                "modal": {
                    "ondismiss": function(){
                        payBtn.innerText = "Send Tip";
                        payBtn.disabled = false;
                    }
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();
        });
    </script>
</body>
</html>
