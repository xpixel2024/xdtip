<!DOCTYPE html>
<html>
<head>
    <style>
        body { background: transparent; color: white; font-family: sans-serif; overflow: hidden; }
        .bar-bg { width: 400px; height: 30px; background: #222; border: 1px solid #00f3ff; position: relative; }
        .bar-fill { height: 100%; background: linear-gradient(90deg, #00f3ff, #ff00ea); width: 0%; transition: width 1s; }
        .text { position: absolute; width: 100%; text-align: center; top: 5px; font-weight: bold; text-shadow: 1px 1px 2px black; }
    </style>
</head>
<body>
    <div id="reason" style="margin-bottom: 5px; color: #00f3ff; font-size: 14px; text-transform: uppercase;">Loading...</div>
    <div class="bar-bg">
        <div id="bar" class="bar-fill"></div>
        <div class="text"><span id="current">0</span> / <span id="target">0</span></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>
    <script>
        const client = supabase.createClient('<%= supabaseUrl %>', '<%= supabaseKey %>');
        const username = "<%= username %>";

        async function updateProgress() {
            const { data: settings } = await client.from('goal_settings').select('*').eq('username', username).single();
            const { data: tips } = await client.from('tips').select('amount').eq('username', username);
            
            const total = tips ? tips.reduce((s, t) => s + parseFloat(t.amount), 0) : 0;
            const goal = settings ? settings.goal_amount : 1000;
            
            document.getElementById('reason').innerText = settings ? settings.goal_reason : "Goal";
            document.getElementById('current').innerText = "₹" + total;
            document.getElementById('target').innerText = "₹" + goal;
            document.getElementById('bar').style.width = Math.min((total / goal) * 100, 100) + "%";
        }

        client.channel('any').on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'tips' }, updateProgress).subscribe();
        updateProgress();
    </script>
</body>
</html>
