<!DOCTYPE html>
<html lang="en">
<head>
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root { --neon: #00f3ff; --magenta: #ff00ea; }
        body { background: transparent; margin: 0; padding: 10px; font-family: 'Rajdhani', sans-serif; color: white; overflow: hidden; }

        .goal-wrapper {
            width: 450px; background: rgba(5, 8, 20, 0.9);
            border: 1px solid rgba(0, 243, 255, 0.3); padding: 15px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.5); position: relative;
        }

        .goal-header { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 18px; text-transform: uppercase; letter-spacing: 1px; }
        .reason { color: var(--neon); font-family: 'Share Tech Mono', monospace; }
        
        .progress-container {
            width: 100%; height: 22px; background: rgba(255, 255, 255, 0.05);
            border: 1px solid #333; position: relative; overflow: hidden;
        }

        .progress-bar {
            height: 100%; width: 0%; 
            background: linear-gradient(90deg, var(--neon), var(--magenta));
            box-shadow: 0 0 15px var(--neon);
            transition: width 1.5s cubic-bezier(0.17, 0.67, 0.83, 0.67);
        }

        .stats { margin-top: 8px; text-align: right; font-size: 14px; font-family: 'Share Tech Mono', monospace; opacity: 0.8; }
    </style>
</head>
<body>
    <div class="goal-wrapper">
        <div class="goal-header">
            <span id="reason-text">INITIALIZING...</span>
            <span id="percent-text">0%</span>
        </div>
        <div class="progress-container">
            <div id="bar" class="progress-bar"></div>
        </div>
        <div class="stats">
            <span id="current">₹0</span> / <span id="target">₹0</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>
    <script>
        // Replace with your PUBLIC Supabase credentials
        const supabaseUrl = 'YOUR_SUPABASE_URL';
        const supabaseKey = 'YOUR_SUPABASE_ANON_KEY';
        const client = supabase.createClient(supabaseUrl, supabaseKey);
        const user = "<%= username %>";

        async function fetchGoalData() {
            // 1. Get Goal Settings
            const { data: settings } = await client.from('goal_settings').select('*').ilike('username', user).maybeSingle();
            
            // 2. Get Total Tips Amount
            const { data: tips } = await client.from('tips').select('amount').ilike('username', user);
            
            const totalRaised = tips ? tips.reduce((sum, t) => sum + parseFloat(t.amount), 0) : 0;
            const target = settings ? settings.goal_amount : 1000;
            const percentage = Math.min((totalRaised / target) * 100, 100).toFixed(1);

            // Update HTML
            document.getElementById('reason-text').innerText = settings ? settings.goal_reason : "TIP GOAL";
            document.getElementById('target').innerText = `₹${target}`;
            document.getElementById('current').innerText = `₹${totalRaised}`;
            document.getElementById('percent-text').innerText = `${percentage}%`;
            document.getElementById('bar').style.width = `${percentage}%`;
        }

        // Listen for Realtime inserts into 'tips' table
        client.channel('any')
            .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'tips' }, payload => {
                fetchGoalData();
            })
            .subscribe();

        // Initial Load
        fetchGoalData();
    </script>
</body>
</html>
