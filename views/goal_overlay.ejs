<!DOCTYPE html>
<html>
<head>
    <style>
        body { background: transparent; color: white; font-family: 'Rajdhani', sans-serif; overflow: hidden; }
        .goal-container { width: 400px; padding: 20px; background: rgba(0,0,0,0.8); border: 1px solid #00f3ff; }
        .progress-bg { width: 100%; height: 25px; background: #222; border-radius: 5px; overflow: hidden; }
        .progress-bar { height: 100%; background: linear-gradient(90deg, #00f3ff, #ff00ea); width: 0%; transition: width 1s; }
        .goal-info { display: flex; justify-content: space-between; margin-bottom: 5px; font-weight: bold; }
        .reason { text-align: center; margin-top: 10px; color: #00f3ff; text-transform: uppercase; letter-spacing: 2px; }
    </style>
</head>
<body>
    <div class="goal-container">
        <div class="goal-info">
            <span id="current">₹0</span>
            <span id="target">Goal: ₹0</span>
        </div>
        <div class="progress-bg">
            <div id="bar" class="progress-bar"></div>
        </div>
        <div id="reason" class="reason">LOADING UPLINK...</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>
    <script>
        const supabase = supabase.createClient('YOUR_URL', 'YOUR_KEY');
        const username = "<%= username %>";

        async function updateUI() {
            // 1. Get Goal Config
            const { data: config } = await supabase.from('goal_settings').select('*').eq('username', username).single();
            // 2. Get Sum of all tips
            const { data: tips } = await supabase.from('tips').select('amount').eq('username', username);
            
            const total = tips.reduce((sum, t) => sum + t.amount, 0);
            const target = config?.goal_amount || 1000;
            const percent = Math.min((total / target) * 100, 100);

            document.getElementById('current').innerText = `₹${total}`;
            document.getElementById('target').innerText = `Goal: ₹${target}`;
            document.getElementById('reason').innerText = config?.goal_reason || "Tip Goal";
            document.getElementById('bar').style.width = percent + "%";
        }

        // Listen for new tips in Realtime
        supabase.channel('public:tips')
            .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'tips' }, updateUI)
            .subscribe();

        updateUI(); // Initial load

supabase.channel('custom-filter-channel') // Any name works here
  .on(
    'postgres_changes', 
    { 
      event: 'INSERT',   // Must be 'INSERT' (capitalized)
      schema: 'public', 
      table: 'tips'      // Must match your table name exactly
    }, 
    (payload) => {
      console.log('Change received!', payload);
      updateUI(); // This function recalculates the bar
    }
  )
  .subscribe();
    </script>
</body>
</html>
