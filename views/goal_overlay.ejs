<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        :root { --progress: <%= (goal_current / goal_amount) * 100 %>%; }
        body { margin: 0; padding: 10px; font-family: 'Arial', sans-serif; overflow: hidden; color: white; }
        .goal-wrapper { width: 450px; background: rgba(0,0,0,0.7); padding: 15px; border-radius: 10px; border: 2px solid #333; }
        .goal-title { font-weight: bold; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
        .progress-container { width: 100%; height: 25px; background: #222; border-radius: 20px; position: relative; overflow: hidden; }
        #bar { 
            height: 100%; width: var(--progress); 
            background: linear-gradient(90deg, #fbc2eb 0%, #a6c1ee 100%); 
            transition: width 0.8s cubic-bezier(0.17, 0.67, 0.83, 0.67); 
        }
        .stats { position: absolute; width: 100%; text-align: center; top: 2px; font-weight: 800; text-shadow: 1px 1px 2px #000; }
    </style>
</head>
<body>

<div class="goal-wrapper">
    <div class="goal-title" id="title"><%= goal_reason %></div>
    <div class="progress-container">
        <div id="bar"></div>
        <div class="stats">
            $<span id="current"><%= goal_current %></span> / $<span id="total"><%= goal_amount %></span>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const token = "<%= obsToken %>";
    
    socket.emit('join-goal', token);

    socket.on('update-goal', (data) => {
        const percent = (data.current / <%= goal_amount %>) * 100;
        document.getElementById('bar').style.width = percent + '%';
        document.getElementById('current').innerText = data.current;
    });
</script>
</body>
</html>
