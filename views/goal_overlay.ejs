<!DOCTYPE html>
<html>
<head>
    <style>
        body { background: transparent; margin: 0; padding: 10px; font-family: sans-serif; color: white; overflow: hidden; }
        .container { width: 400px; background: rgba(0,0,0,0.8); border: 1px solid #00f3ff; padding: 15px; }
        .bar-bg { width: 100%; height: 25px; background: #111; border: 1px solid #333; position: relative; }
        .bar-fill { height: 100%; background: linear-gradient(90deg, #00f3ff, #ff00ea); width: 0%; transition: width 1s; }
        .label-box { display: flex; justify-content: space-between; margin-bottom: 5px; font-weight: bold; font-size: 14px; text-transform: uppercase; }
    </style>
</head>
<body>
    <div class="container">
        <div class="label-box">
            <span id="rsn-text">LOADING...</span>
            <span id="perc-text">0%</span>
        </div>
        <div class="bar-bg">
            <div id="bar" class="bar-fill"></div>
        </div>
        <div style="text-align: right; font-size: 12px; margin-top: 5px; opacity: 0.7;">
            <span id="cur-amt">₹0</span> / <span id="tar-amt">₹0</span>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js"></script>
    <script>
        const client = supabase.createClient('<%= supabaseUrl %>', '<%= supabaseKey %>');
        const user = "<%= username %>";

        async function updateUI() {
            const { data: settings } = await client.from('goal_settings').select('*').eq('username', user).single();
            const { data: tips } = await client.from('tips').select('amount').eq('username', user);
            
            const total = tips ? tips.reduce((sum, t) => sum + parseFloat(t.amount), 0) : 0;
            const target = settings ? settings.goal_amount : 1000;
            const percentage = Math.min((total / target) * 100, 100).toFixed(1);

            document.getElementById('rsn-text').innerText = settings ? settings.goal_reason : "TIP GOAL";
            document.getElementById('tar-amt').innerText = "₹" + target;
            document.getElementById('cur-amt').innerText = "₹" + total;
            document.getElementById('perc-text').innerText = percentage + "%";
            document.getElementById('bar').style.width = percentage + "%";
        }

        client.channel('tips-stream').on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'tips' }, updateUI).subscribe();
        updateUI();
    </script>
</body>
</html>
